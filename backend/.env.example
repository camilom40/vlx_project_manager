# ============================================================
# Gestor de Proyectos Vitralux / VLX — Backend (API)
# Copiar a .env y completar con valores reales.
# NUNCA commitear el .env con credenciales.
# ============================================================

# --- Servidor ---
PORT=4000
# URL del frontend permitida por CORS
FRONTEND_URL=http://localhost:3000

# --- Base de datos (PostgreSQL) ---
# Local:   postgresql://usuario:password@localhost:5432/vitralux_pm
# Railway: usar la DATABASE_URL del servicio PostgreSQL (base separada del cotizador)
DATABASE_URL=

# --- Autenticación (JWT) ---
JWT_SECRET=
# Duración del token, p. ej. 8h, 7d
JWT_EXPIRES_IN=8h

# --- Notificaciones por correo (Nodemailer / SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remitente visible en los correos, p. ej. "Gestor Vitralux <notificaciones@vitralux.co>"
EMAIL_FROM=

# --- Notificaciones por WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número de WhatsApp de Twilio, formato: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
